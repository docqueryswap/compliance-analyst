PINECONE_API_KEY=your_pinecone_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Optional (if you integrate Redis-hosted state outside /tmp locally)
